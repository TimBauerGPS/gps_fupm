# Vite frontend (exposed to browser — safe)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Netlify functions (server-side only — never expose client-side)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Twilio (per-company overrides can be stored in company_settings)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+18885551212

# PostGrid
POSTGRID_API_KEY=your-postgrid-key

# Resend
RESEND_API_KEY=your-resend-key

# Google Sheets nightly sync (base64-encoded JSON service account)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
